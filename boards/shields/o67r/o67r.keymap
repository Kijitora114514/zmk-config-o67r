                &kp LCTRL  &kp LWIN  &kp LALT  O67R_STUDIO_UNLOCK  &trans  &kp LANG2  &kp SPACE  &kp SPACE  &kp LANG1  &trans   &kp HOME   &kp PG_UP  &kp PG_DN  &kp END
            >;
            sensor-bindings = <&encoder_scroll SCRL_UP SCRL_DOWN>;
        };

        layer2 {
