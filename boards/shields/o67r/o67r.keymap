&zip_mouse_gesture {
    always-active;
    suppress-movement;
    enable-eager-mode;
    stroke-size = <80>;
    idle-timeout-ms = <150>;

    swipe_up {
        pattern = <GESTURE_UP>;
        bindings = <&kp A>;
    };

    swipe_down {
        pattern = <GESTURE_DOWN>;
        bindings = <&kp S>;
    };
};

#ifdef CONFIG_INPUT_CST816S
&touch_listener {
    input-processors = <
        &zip_absolute_to_relative
        &zip_mouse_gesture
    >;
};
#endif
