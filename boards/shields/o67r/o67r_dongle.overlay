#include "o67r.dtsi"

&kscan {
    compatible = "zmk,kscan-gpio-direct";
    //wakeup-source;
    input-gpios
        = <&gpio0 28 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)> // unlock
        ;
    
};
